upstream upstream_editorial {
    server 10.0.2.20:8081;
    server 10.0.2.10:8081;
}

upstream upstream_autor {
    server 10.0.2.20:8082;
    server 10.0.2.10:8082;
}

upstream upstream_libro {
    server 10.0.2.20:8083;
    server 10.0.2.10:8083;
}

server {
    listen 80;
    server_name www.distribuidos.net servicios.distribuidos.net;
    
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name www.distribuidos.net;

    ssl_certificate /etc/nginx/ssl/distribuidos.crt;
    ssl_certificate_key /etc/nginx/ssl/distribuidos.key;

    root /var/www/html;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~ ^/editorial {
        proxy_pass http://upstream_editorial;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
    }

    location ~ ^/autor {
        proxy_pass http://upstream_autor;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
    }

    location ~ ^/libro {
        proxy_pass http://upstream_libro;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto https;
    }
}

server {
    listen 443 ssl;
    server_name servicios.distribuidos.net;

    ssl_certificate /etc/nginx/ssl/distribuidos.crt;
    ssl_certificate_key /etc/nginx/ssl/distribuidos.key;

    location / {
        proxy_pass http://upstream_libro;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}